{
  "name": "freeport",
  "version": "0.1.0",
  "description": "Open-source LLM gateway — prompt management, model fallback, caching, cost tracking, guardrails",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp src/db/migrations/*.sql dist/db/migrations/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build:ui": "cd admin-ui && npm run build",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "ajv": "^8.17.1",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "undici": "^7.3.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.12.0",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^4.1.2"
  }
}
